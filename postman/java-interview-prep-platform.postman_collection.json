{
  "info": {
    "_postman_id": "7e3f6e5f-7f1d-4c63-9d32-java-interview-prep",
    "name": "Java Interview Prep Platform",
    "description": "Self-contained Postman collection for the Java Interview Prep Platform. Import this collection and run the requests in order. Collection variables hold baseUrl, tokens, sample request values, and IDs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "demoEmail",
      "value": "demo-admin@prep.local",
      "type": "string"
    },
    {
      "key": "demoPassword",
      "value": "Interview@123",
      "type": "string"
    },
    {
      "key": "demoFullName",
      "value": "Postman Demo Admin",
      "type": "string"
    },
    {
      "key": "demoRoleId",
      "value": "2",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin User - captures tokens",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `postman-admin-${Date.now()}@prep.local`;",
                  "pm.collectionVariables.set('demoEmail', email);",
                  "pm.collectionVariables.set('demoPassword', 'Interview@123');",
                  "pm.collectionVariables.set('demoFullName', 'Postman Demo Admin');",
                  "pm.collectionVariables.set('demoRoleId', '2');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"fullName\": \"{{demoFullName}}\",\n  \"roleId\": {{demoRoleId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Creates a new admin user for the current Postman run and stores accessToken and refreshToken as collection variables."
          }
        },
        {
          "name": "Login - captures tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Logs in using the user created by the Register request and refreshes collection token variables."
          }
        },
        {
          "name": "Refresh Token - captures tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Rotates the refresh token and stores the new accessToken and refreshToken."
          }
        }
      ]
    },
    {
