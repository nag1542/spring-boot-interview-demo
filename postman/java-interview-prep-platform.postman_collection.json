              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create product returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('productId', String(body.id));",
