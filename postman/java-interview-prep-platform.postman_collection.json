            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spring Boot Production Readiness\",\n  \"price\": 79.99,\n  \"stock\": 100\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
